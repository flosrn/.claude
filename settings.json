{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ALLOW_GIT_COMMIT": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "GIT_AUTHOR_EMAIL": "flosrn@users.noreply.github.com",
    "GIT_AUTHOR_NAME": "Claude Code",
    "GIT_COMMITTER_EMAIL": "flosrn@users.noreply.github.com",
    "GIT_COMMITTER_NAME": "Claude Code",
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "MAX_THINKING_TOKENS": "31999",
    "RIPGREP_CONFIG_PATH": "/Users/flo/.config/ripgrep/.emptyripgreprc"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(npm run :*)",
      "Bash(git :*)",
      "Bash(pnpm :*)",
      "Bash(gh :*)",
      "Bash(cd :*)",
      "Bash(ls :*)",
      "Bash(node :*)",
      "Bash(pnpm:*)",
      "Bash(gh:*)",
      "Edit",
      "Bash(ls:*)",
      "Bash(git:*)",
      "mcp__context7",
      "mcp__exa",
      "Bash(claude mcp add:*)",
      "Bash(pnpm ts:*)",
      "Bash(mkdir:*)",
      "WebFetch(domain:upstash.com)",
      "Bash(npx prisma migrate dev:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm test:*)",
      "Bash(rm:*)",
      "Bash(claude mcp:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "Bash(pnpm lint:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "mcp__playwright-mobile__browser_navigate",
      "mcp__playwright-mobile__browser_take_screenshot",
      "mcp__playwright-desktop__browser_navigate",
      "mcp__playwright-desktop__browser_take_screenshot",
      "mcp__exa__get_code_context_exa"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/ghostty-attention.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notchi-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/apex-step-done.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook hook-ts-quality-gate.ts"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notchi-hook.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notchi-hook.sh"
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notchi-hook.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook command-validator/src/cli.ts"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notchi-hook.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notchi-hook.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook hook-git-context.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notchi-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook hook-typecheck-stop.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notchi-hook.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/ghostty-attention.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notchi-hook.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify-openclaw.sh task-completed"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notchi-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/bin/run-hook statusline/src/index.ts",
    "padding": 0
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "marketing-skills@marketingskills": false,
    "plugin-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "vercel-plugin@vercel-vercel-plugin": true
  },
  "extraKnownMarketplaces": {
    "vercel-vercel-plugin": {
      "source": {
        "source": "directory",
        "path": "/Users/flo/.cache/plugins/github.com-vercel-vercel-plugin"
      }
    }
  },
  "feedbackSurveyRate": 0,
  "effortLevel": "high",
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "worktree": {
    "symlinkDirectories": ["node_modules", ".next", "dist"]
  },
  "allowedDirectories": [
    "/home/node",
    "/home/node/.openclaw",
    "/home/node/.openclaw/code-projects",
    "/home/node/.openclaw/code-projects/plans-config-ssot",
    "/home/node/.openclaw/workspace",
    "/home/node/projects/gapila",
    "/tmp"
  ],
  "trustedDirectories": [
    "/home/node",
    "/home/node/.openclaw",
    "/home/node/.openclaw/code-projects",
    "/home/node/.openclaw/code-projects/plans-config-ssot",
    "/home/node/.openclaw/workspace",
    "/home/node/projects/gapila",
    "/tmp"
  ]
}
