{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ALLOW_GIT_COMMIT": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "GIT_AUTHOR_EMAIL": "flosrn@users.noreply.github.com",
    "GIT_AUTHOR_NAME": "Claude Code",
    "GIT_COMMITTER_EMAIL": "flosrn@users.noreply.github.com",
    "GIT_COMMITTER_NAME": "Claude Code",
    "MAX_MCP_OUTPUT_TOKENS": "125000",
    "MAX_THINKING_TOKENS": "31999",
    "RIPGREP_CONFIG_PATH": "/Users/flo/.config/ripgrep/.emptyripgreprc"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(claude mcp:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(node:*)",
      "Bash(npm run:*)",
      "Bash(npx prisma migrate dev:*)",
      "Bash(pnpm:*)",
      "Bash(rm:*)",
      "WebFetch(domain:upstash.com)",
      "mcp__context7",
      "mcp__exa",
      "mcp__playwright-mobile__browser_navigate",
      "mcp__playwright-mobile__browser_take_screenshot",
      "mcp__playwright-desktop__browser_navigate",
      "mcp__playwright-desktop__browser_take_screenshot",
      "mcp__gsc__get_capabilities",
      "mcp__gsc__list_properties",
      "mcp__gsc__get_site_details",
      "mcp__gsc__get_search_analytics",
      "mcp__gsc__get_performance_overview",
      "mcp__gsc__compare_search_periods",
      "mcp__gsc__get_search_by_page_query",
      "mcp__gsc__get_advanced_search_analytics",
      "mcp__gsc__inspect_url_enhanced",
      "mcp__gsc__batch_url_inspection",
      "mcp__gsc__check_indexing_issues",
      "mcp__gsc__get_sitemaps",
      "mcp__gsc__get_sitemap_details",
      "mcp__gsc__list_sitemaps_enhanced",
      "mcp__gsc__get_creator_info",
      "mcp__gsc__reauthenticate"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude",
            "timeout": 86400
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook hook-ts-quality-gate.ts"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/flo/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".next",
      "dist"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/bin/run-hook statusline/src/index.ts",
    "padding": 0
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "marketing-skills@marketingskills": true,
    "plugin-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "vercel-plugin@vercel-vercel-plugin": true,
    "llm-wiki@alirezarezvani-claude-skills": true,
    "karpathy-coder@alirezarezvani-claude-skills": true,
    "agenthub@alirezarezvani-claude-skills": true,
    "skill-security-auditor@alirezarezvani-claude-skills": true
  },
  "extraKnownMarketplaces": {
    "alirezarezvani-claude-skills": {
      "source": {
        "source": "github",
        "repo": "alirezarezvani/claude-skills"
      }
    },
    "vercel-vercel-plugin": {
      "source": {
        "source": "directory",
        "path": "/Users/flo/.cache/plugins/github.com-vercel-vercel-plugin"
      },
      "autoUpdate": true
    }
  },
  "feedbackSurveyRate": 0,
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "showThinkingSummaries": true
}
