{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "RIPGREP_CONFIG_PATH": ""
  },
  "hooks": {
    "Stop": [],
    "SubagentStop": [],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify-openclaw.sh task-completed"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify-openclaw.sh needs-attention"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/apex-step-done.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook hook-ts-quality-gate.ts"
          }
        ]
      }
    ]
  }
}
